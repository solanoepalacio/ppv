{
  "name": "ppview-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "codegen": "papi generate",
    "update-types": "papi update",
    "dev": "vite",
    "dev:blockchain": "npm run update-types && vite",
    "build": "npm run codegen && tsc -b && vite build",
    "postinstall": "npm run codegen",
    "lint": "eslint .",
    "fmt": "prettier --write 'src/**/*.{ts,tsx}'",
    "fmt:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "preview": "vite preview",
    "test": "vitest --run"
  },
  "dependencies": {
    "@novasamatech/product-sdk": "^0.6.12",
    "@parity/bulletin-sdk": "^0.1.0",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-api/pjs-signer": "^0.6.21",
    "@polkadot-labs/hdkd": "^0.0.26",
    "@polkadot-labs/hdkd-helpers": "^0.0.27",
    "blakejs": "^1.2.1",
    "libsodium-wrappers": "^0.7.15",
    "multiformats": "^13.4.2",
    "polkadot-api": "^1.23.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.12.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.1",
    "vitest": "^2.0.0"
  }
}
